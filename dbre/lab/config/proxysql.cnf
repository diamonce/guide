datadir="/var/lib/proxysql"

admin_variables =
{
    admin_credentials = "admin:adminpass"
    mysql_ifaces       = "0.0.0.0:6032"
    web_enabled        = true
    restapi_enabled    = true
    web_port           = 6070
}

mysql_variables =
{
    threads                    = 4
    max_connections            = 2048
    default_query_delay        = 0
    default_query_timeout      = 36000000
    have_compress              = true
    poll_timeout               = 2000
    interfaces                 = "0.0.0.0:6033"
    default_schema             = "shopdb"
    stacksize                  = 1048576
    server_version             = "8.0.30"
    connect_timeout_server     = 3000
    monitor_username           = "monitor"
    monitor_password           = "monitorpass"
    monitor_history            = 600000
    monitor_connect_interval   = 60000
    monitor_ping_interval      = 10000
    ping_interval_server_msec  = 10000
    ping_timeout_server        = 200
    commands_stats             = true
    sessions_sort              = true
    connect_retries_on_failure = 10
}

# Backend servers
mysql_servers =
(
    {
        address         = "mysql-primary"
        port            = 3306
        hostgroup       = 0       # write group
        status          = "ONLINE"
        weight          = 1
        compression     = 0
        max_connections = 100
    },
    {
        address         = "mysql-replica1"
        port            = 3306
        hostgroup       = 1       # read group
        status          = "ONLINE"
        weight          = 1
        compression     = 0
        max_connections = 100
    },
    {
        address         = "mysql-replica2"
        port            = 3306
        hostgroup       = 1       # read group
        status          = "ONLINE"
        weight          = 1
        compression     = 0
        max_connections = 100
    }
)

# Users — map app user to hostgroups
mysql_users =
(
    {
        username           = "app"
        password           = "apppass"
        default_hostgroup  = 0    # writes go to primary by default
        active             = 1
    }
)

# Query rules — route SELECTs to replicas
mysql_query_rules =
(
    # ProxySQL 2.5 multiplexing probe — intercept before it reaches MySQL 8.0.
    # MySQL rejects SELECT $$ with "Unknown column '$$'" which fills the error log.
    {
        rule_id              = 1
        active               = 1
        match_pattern        = "^SELECT \$\$"
        multiplex            = 1
        apply                = 1
    },
    {
        rule_id              = 2
        active               = 1
        match_pattern        = "^SELECT .* FOR UPDATE"
        destination_hostgroup = 0    # SELECT FOR UPDATE must go to primary
        apply                = 1
    },
    {
        rule_id              = 3
        active               = 1
        match_pattern        = "^SELECT"
        destination_hostgroup = 1    # all other SELECTs → replicas
        apply                = 1
    }
)
