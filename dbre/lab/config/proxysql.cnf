datadir="/var/lib/proxysql"

admin_variables =
{
    admin_credentials  = "admin:adminpass;radmin:radminpass"
    stats_credentials  = "stats:statspass"
    mysql_ifaces       = "0.0.0.0:6032"
    web_enabled        = true
    web_port           = 6080

    # ── Cluster sync ─────────────────────────────────────────────────────────
    # radmin is already in admin_credentials; reused for inter-node gossip.
    # Each node polls peers every 200 ms. Config changes on any node propagate
    # automatically — change mysql_servers on node-1, node-2 picks it up.
    cluster_username                             = "radmin"
    cluster_password                             = "radminpass"
    cluster_check_interval_ms                    = 200
    cluster_check_status_frequency               = 100
    cluster_mysql_query_rules_save_to_disk       = true
    cluster_mysql_servers_save_to_disk           = true
    cluster_mysql_users_save_to_disk             = true
    cluster_proxysql_servers_save_to_disk        = true
}

# ProxySQL cluster peers — both nodes list each other.
# A node ignores itself in this list; no special per-node config needed.
proxysql_servers =
(
    { hostname = "proxysql",  port = 6032, weight = 1, comment = "node-1" },
    { hostname = "proxysql2", port = 6032, weight = 1, comment = "node-2" }
)

mysql_variables =
{
    threads                    = 4
    max_connections            = 2048
    default_query_delay        = 0
    default_query_timeout      = 36000000
    have_compress              = true
    poll_timeout               = 2000
    interfaces                 = "0.0.0.0:6033"
    default_schema             = "shopdb"
    stacksize                  = 1048576
    server_version             = "8.0.30"
    connect_timeout_server     = 3000
    monitor_username           = "monitor"
    monitor_password           = "monitorpass"
    monitor_history            = 600000
    monitor_connect_interval   = 60000
    monitor_ping_interval      = 10000
    ping_interval_server_msec  = 10000
    ping_timeout_server        = 200
    commands_stats             = true
    sessions_sort              = true
    connect_retries_on_failure = 10
}

# Backend servers
mysql_servers =
(
    {
        address         = "mysql-primary"
        port            = 3306
        hostgroup       = 0       # write group
        status          = "ONLINE"
        weight          = 1
        compression     = 0
        max_connections = 100
    },
    {
        address         = "mysql-replica1"
        port            = 3306
        hostgroup       = 1       # read group
        status          = "ONLINE"
        weight          = 1
        compression     = 0
        max_connections = 100
    },
    {
        address         = "mysql-replica2"
        port            = 3306
        hostgroup       = 1       # read group
        status          = "ONLINE"
        weight          = 1
        compression     = 0
        max_connections = 100
    }
)

# Users — map app user to hostgroups
mysql_users =
(
    {
        username           = "app"
        password           = "apppass"
        default_hostgroup  = 0    # writes go to primary by default
        active             = 1
    }
)

# Query rules — route SELECTs to replicas + transparent caching
#
# How ProxySQL query cache works:
#   When a rule has cache_ttl set, ProxySQL hashes the query text and stores
#   the result in its internal cache (memory). On the next identical query,
#   ProxySQL returns the cached result without touching MySQL at all.
#   The app sends normal SQL — zero code changes required.
#
# Cache TTL values (milliseconds):
#   products catalog  — 30 000ms (30s): product names/prices rarely change
#   aggregate counts  —  5 000ms  (5s): acceptable staleness for dashboards
#
mysql_query_rules =
(
    # Rule 1 — ProxySQL 2.5 multiplexing probe (internal, must be first)
    {
        rule_id              = 1
        active               = 1
        match_pattern        = "^SELECT \$\$"
        multiplex            = 1
        apply                = 1
    },
    # Rule 2 — SELECT FOR UPDATE always hits primary (locking read)
    {
        rule_id              = 2
        active               = 1
        match_pattern        = "^SELECT .* FOR UPDATE"
        destination_hostgroup = 0
        apply                = 1
    },
    # Rule 3 — Cache product catalog reads (30s TTL)
    # products and order_items are reference data; staleness is acceptable.
    {
        rule_id               = 3
        active                = 1
        match_pattern         = "^SELECT .* FROM products"
        destination_hostgroup = 1
        cache_ttl             = 30000
        apply                 = 1
    },
    # Rule 4 — Cache aggregate/count queries (5s TTL)
    # Dashboard queries like "how many orders today" tolerate slight lag.
    {
        rule_id               = 4
        active                = 1
        match_pattern         = "^SELECT COUNT"
        destination_hostgroup = 1
        cache_ttl             = 5000
        apply                 = 1
    },
    # Rule 5 — All other SELECTs → replicas (no cache)
    {
        rule_id              = 5
        active               = 1
        match_pattern        = "^SELECT"
        destination_hostgroup = 1
        apply                = 1
    }
)
