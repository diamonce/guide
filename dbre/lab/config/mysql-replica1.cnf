[mysqld]
server-id           = 2
bind-address        = 0.0.0.0

# Read-only — replicas should not accept writes directly
read-only           = ON
super-read-only     = ON

# GTID
gtid-mode           = ON
enforce-gtid-consistency = ON

# Relay log
relay-log           = relay-bin
log-slave-updates   = ON      # allows chaining replicas
binlog-format       = ROW

# Performance
innodb-buffer-pool-size   = 256M
max-connections           = 200

slow-query-log            = ON
slow-query-log-file       = /var/log/mysql/slow.log
long-query-time           = 1
